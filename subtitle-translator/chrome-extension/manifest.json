{
    "manifest_version": 3,
    "name": "Udemy Subtitle Translator",
    "description": "Dịch phụ đề Udemy sang tiếng Việt qua Antigravity",
    "version": "1.0.5",
    "permissions": [
        "webRequest",
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "*://*.udemy.com/*",
        "*://*.udemycdn.com/*",
        "*://api.1min.ai/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://dunremote.fastddns.org:10100/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.udemy.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "subtitle-overlay.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Udemy Subtitle Translator"
    },
    "options_page": "settings.html",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}